{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "jsxImportSource": "vue",
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "lib",
    "tsBuildInfoFile": "./lib/tsconfig.tsbuildinfo"
  },
  "include": ["src", "*"],
  "exclude": ["src/**/*.spec.ts"],
  "references": [
    { "path": "./" },
  ]
}
